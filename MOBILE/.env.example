# Expo Environment Variables
# IMPORTANT: Copy this file to .env and fill in your own values.
# Never commit the real .env file to version control.

# API URL
EXPO_PUBLIC_API_URL=https://your-backend-url.example.com

# Stripe (Publishable key — starts with pk_test_ or pk_live_)
# Get from: https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_KEY=pk_test_REPLACE_WITH_YOUR_KEY

# PayPal Client ID
# Get from: https://developer.paypal.com/dashboard/applications
EXPO_PUBLIC_PAYPAL_CLIENT_ID=REPLACE_WITH_YOUR_PAYPAL_CLIENT_ID

# Environment: development | production
EXPO_PUBLIC_ENV=development
